# Database (Neon Postgres)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Server
PORT=5000
NODE_ENV=production
APP_URL=https://wowbydany.com

# Admin
ADMIN_PASSWORD=change-me

# Stripe
STRIPE_SECRET_KEY=sk_live_xxx
VITE_STRIPE_PUBLIC_KEY=pk_live_xxx
# Test keys (optional — used when NODE_ENV != production)
TESTING_STRIPE_SECRET_KEY=sk_test_xxx
VITE_TESTING_STRIPE_PUBLIC_KEY=pk_test_xxx

# Email (SMTP — Gmail App Password, SES, or any SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=jewelryboutiquewow@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="WOW by Dany" <jewelryboutiquewow@gmail.com>

# AWS S3 (file uploads)
AWS_REGION=us-east-1
S3_BUCKET=wow-jewelry-uploads
# AWS credentials — set via IAM role on ECS, or explicitly:
# AWS_ACCESS_KEY_ID=xxx
# AWS_SECRET_ACCESS_KEY=xxx
